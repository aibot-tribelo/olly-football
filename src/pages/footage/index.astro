---
import Layout from '../../layouts/Layout.astro';

const BASE = import.meta.env.BASE_URL;

const videos = [
  { id: 'TMCEEEKN_fk', title: 'Calne U16 vs Swindon Supermarine — Goal', description: 'September 2024', type: 'match' },
  { id: '6XvCLzA53YM', title: 'Dutch International Tournament — Clips (1)', description: 'Summer 2024', type: 'highlight' },
  { id: 'C_TTKECG0Cc', title: 'Dutch International Tournament — Clips (2)', description: 'Summer 2024', type: 'highlight' },
  { id: 'KkvmGcuv8nE', title: 'AFC Corsham U15 vs Bradford — Cup Final Goals', description: 'Cup Final 2023-24', type: 'match' },
  { id: 'LhVojvKhg2U', title: 'JPL Goal of the Month — FC Wilts U15', description: 'October 2023', type: 'highlight' },
  { id: '6YTtkB6Qh_g', title: 'Melksham Town vs Chippenham Town — Clip', description: 'Melksham Town Reserves', type: 'match' },
];

const typeColors: Record<string, string> = {
  highlight: 'bg-gold/10 text-gold border-gold/20',
  match: 'bg-fire/10 text-fire border-fire/20',
  training: 'bg-blue-500/10 text-blue-400 border-blue-400/20',
};
---

<Layout title="Footage — Olly Robinson" description="Match footage, highlights and goals for Olly Robinson — Striker.">

  <nav class="fixed top-0 left-0 right-0 z-50 bg-pitch/80 backdrop-blur-md border-b border-pitch-line/50">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 h-14 flex items-center justify-between">
      <a href={BASE} class="font-['Oswald'] text-sm uppercase tracking-[0.3em] text-gold hover:text-cream transition-colors">← Back to Profile</a>
      <span class="font-['Oswald'] text-sm uppercase tracking-[0.3em] text-cream-muted">Footage & Clips</span>
    </div>
  </nav>

  <main id="main" class="min-h-screen pitch-pattern pt-24 pb-20">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">

      <!-- Header -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-px w-12 bg-gold"></div>
          <span class="font-['Oswald'] text-xs uppercase tracking-[0.3em] text-gold">Match Footage & Highlights</span>
        </div>
        <h1 class="font-['Oswald'] text-5xl sm:text-6xl lg:text-7xl font-bold uppercase leading-[0.85] tracking-tight mb-4">
          <span class="text-cream">Watch</span> <span class="text-gold">Olly</span>
        </h1>
        <p class="text-cream-muted text-sm max-w-lg">
          Match highlights, goals and tournament clips. Tap to play.
        </p>
      </div>

      <!-- Video Grid — thumbnails -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {videos.map(v => (
          <button class="group text-left video-thumb cursor-pointer" data-video-id={v.id} data-video-title={v.title}>
            <div class="relative aspect-video rounded-sm overflow-hidden bg-pitch-light">
              <img
                src={`https://img.youtube.com/vi/${v.id}/maxresdefault.jpg`}
                alt={v.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-pitch/30 group-hover:bg-pitch/10 transition-colors flex items-center justify-center">
                <div class="w-14 h-14 bg-gold/90 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform shadow-lg shadow-gold/20">
                  <svg class="w-6 h-6 text-pitch ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-2 mt-3">
              <span class={`text-xs font-semibold uppercase tracking-wider border px-2 py-0.5 rounded-sm ${typeColors[v.type]}`}>{v.type}</span>
            </div>
            <h3 class="font-['Oswald'] text-sm uppercase tracking-wide text-cream group-hover:text-gold transition-colors mt-1.5">{v.title}</h3>
            <p class="text-xs text-cream-muted mt-0.5">{v.description}</p>
          </button>
        ))}
      </div>

      <!-- More coming -->
      <div class="mt-16 text-center border border-dashed border-pitch-line rounded-sm p-10">
        <div class="font-['Oswald'] text-xl uppercase tracking-wide text-cream-muted mb-2">More footage coming soon</div>
        <p class="text-xs text-cream-muted">Full match recordings and new highlight reels will be added throughout the season.</p>
      </div>

    </div>
  </main>

</Layout>

<script>
  // Create video modal
  const modal = document.createElement('div');
  modal.id = 'video-modal';
  modal.className = 'fixed inset-0 z-[100] bg-black/95 backdrop-blur-sm hidden items-center justify-center flex-col';
  modal.setAttribute('role', 'dialog');
  modal.setAttribute('aria-modal', 'true');
  modal.setAttribute('aria-label', 'Video player');
  modal.innerHTML = `
    <button id="vm-close" aria-label="Close video" class="absolute top-4 right-4 z-10 w-14 h-14 flex items-center justify-center text-white/70 hover:text-white bg-white/10 hover:bg-white/20 rounded-full text-3xl cursor-pointer transition-colors focus:outline-2 focus:outline-gold focus:outline-offset-2">&times;</button>
    <div id="vm-container" class="w-[95vw] max-w-5xl aspect-video relative">
      <iframe id="vm-iframe" class="w-full h-full rounded-sm" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
    </div>
    <div id="vm-title" class="text-sm text-white/80 mt-4 font-medium text-center px-4"></div>
  `;
  document.body.appendChild(modal);

  const vmIframe = document.getElementById('vm-iframe') as HTMLIFrameElement;
  const vmTitle = document.getElementById('vm-title') as HTMLElement;

  function openVideo(id: string, title: string) {
    vmIframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
    vmTitle.textContent = title;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeVideo() {
    vmIframe.src = '';
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  // Thumbnail click handlers
  document.querySelectorAll('.video-thumb').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-video-id');
      const title = btn.getAttribute('data-video-title');
      if (id) openVideo(id, title || '');
    });
  });

  document.getElementById('vm-close')?.addEventListener('click', closeVideo);

  // Close on backdrop click
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeVideo();
  });

  // Keyboard
  document.addEventListener('keydown', (e) => {
    if (modal.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeVideo();
  });

  // Swipe down to close
  let touchStartY = 0;
  modal.addEventListener('touchstart', (e: TouchEvent) => {
    touchStartY = e.changedTouches[0].screenY;
  }, { passive: true });

  modal.addEventListener('touchend', (e: TouchEvent) => {
    const dy = touchStartY - e.changedTouches[0].screenY;
    if (dy < -80) closeVideo();
  }, { passive: true });
</script>
